---
import { publications, scholarProfile } from '../data/publications.js';

// Sort by citations descending, then group by year (newest first)
const sorted = [...publications].sort((a, b) => b.citations - a.citations);

const byYear: Record<number, typeof publications> = {};
for (const pub of sorted) {
  if (!byYear[pub.year]) byYear[pub.year] = [];
  byYear[pub.year].push(pub);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const typeLabel: Record<string, string> = {
  journal: 'Journal',
  conference: 'Conference',
  workshop: 'Workshop',
  preprint: 'Preprint',
};

const typeColor: Record<string, string> = {
  journal: '#2563eb',
  conference: '#7c3aed',
  workshop: '#16a34a',
  preprint: '#ea580c',
};

// Title link priority:
//  1. Published journal DOI (doi.org)
//  2. Specific Scholar citation page (has view_op=view_citation)
//  3. arXiv abstract page (fallback)
//  4. Generic Scholar profile (last resort)
const pubLink = (pub: any) => {
  if (pub.scholar_url?.includes('view_op=view_citation')) return pub.scholar_url;
  if (pub.doi?.includes('doi.org')) return pub.doi;
  return pub.scholar_url || null;
};
---

<section id="publications" class="arclab-section">
  <div class="arclab-container">

    <!-- Header -->
    <div class="text-center mb-6 arclab-fade-in">
      <h2 class="arclab-heading-2 mb-4">Publications</h2>
      <p class="arclab-text text-lg max-w-2xl mx-auto">
        Research publications and academic contributions
      </p>
    </div>

    <!-- Scholar stats -->
    <div class="stats-row arclab-fade-in" style="animation-delay: 0.1s;">
      <div class="stat">
        <span class="stat-num">{scholarProfile.totalCitations}</span>
        <span class="stat-lbl">Citations</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">{scholarProfile.hIndex}</span>
        <span class="stat-lbl">h-index</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">{scholarProfile.i10Index}</span>
        <span class="stat-lbl">i10-index</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">{publications.length}</span>
        <span class="stat-lbl">Publications</span>
      </div>
    </div>

    <!-- Publications by year -->
    <div class="pub-list arclab-fade-in" style="animation-delay: 0.2s;">
      {years.map((year) => {
        const pubs = byYear[year];
        const top  = pubs[0];
        const rest = pubs.slice(1);
        return (
          <div class="year-section">

            <!-- Year divider -->
            <div class="year-divider">
              <span class="year-label">{year}</span>
              <div class="year-rule"></div>
            </div>

            <!-- Top pub — always visible -->
            <div class="pub-card">
              <div class="pub-body">
                <div class="pub-meta">
                  <span class="type-badge" style={`background:${typeColor[top.type] ?? '#475569'}`}>
                    {typeLabel[top.type] ?? top.type}
                  </span>
                  {top.citations > 0 && (
                    <span class="cite-badge">
                      {top.citations} {top.citations === 1 ? 'citation' : 'citations'}
                    </span>
                  )}
                </div>
                <h4 class="pub-title">
                  {pubLink(top) ? (
                    <a href={pubLink(top)} target="_blank" rel="noopener noreferrer">
                      {top.title}
                    </a>
                  ) : top.title}
                </h4>
                <p class="pub-authors">{top.authors.join(', ')}</p>
                <p class="pub-venue">{top.venue}</p>
                {top.abstract && (
                  <p class="pub-abstract">
                    {top.abstract.length > 220 ? top.abstract.slice(0, 220) + '…' : top.abstract}
                  </p>
                )}
              </div>
              <div class="pub-links">
                {top.pdfUrl && (
                  <a href={top.pdfUrl} target="_blank" rel="noopener noreferrer" class="pub-link">PDF</a>
                )}
              </div>
            </div>

            <!-- Extra pubs — collapsed -->
            {rest.length > 0 && (
              <details class="more-block">
                <summary class="more-summary">
                  <svg class="more-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                  {rest.length} more {rest.length === 1 ? 'publication' : 'publications'}
                </summary>
                <div class="more-inner">
                  {rest.map(pub => (
                    <div class="pub-card">
                      <div class="pub-body">
                        <div class="pub-meta">
                          <span class="type-badge" style={`background:${typeColor[pub.type] ?? '#475569'}`}>
                            {typeLabel[pub.type] ?? pub.type}
                          </span>
                          {pub.citations > 0 && (
                            <span class="cite-badge">
                              {pub.citations} {pub.citations === 1 ? 'citation' : 'citations'}
                            </span>
                          )}
                        </div>
                        <h4 class="pub-title">
                          {pubLink(pub) ? (
                            <a href={pubLink(pub)} target="_blank" rel="noopener noreferrer">
                              {pub.title}
                            </a>
                          ) : pub.title}
                        </h4>
                        <p class="pub-authors">{pub.authors.join(', ')}</p>
                        <p class="pub-venue">{pub.venue}</p>
                        {pub.abstract && (
                          <p class="pub-abstract">
                            {pub.abstract.length > 220 ? pub.abstract.slice(0, 220) + '…' : pub.abstract}
                          </p>
                        )}
                      </div>
                      <div class="pub-links">
                        {pub.pdfUrl && (
                          <a href={pub.pdfUrl} target="_blank" rel="noopener noreferrer" class="pub-link">PDF</a>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </details>
            )}

          </div>
        );
      })}
    </div>

    <!-- Scholar link -->
    <div class="text-center mt-10">
      <a
        href={scholarProfile.profileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="arclab-button-secondary text-sm inline-flex items-center gap-2"
      >
        <i class="fas fa-graduation-cap"></i>
        View full profile on Google Scholar
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Stats ── */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .stat { text-align: center; }
  .stat-num { display: block; font-size: 2rem; font-weight: 700; color: #fff; line-height: 1; }
  .stat-lbl { display: block; font-size: 0.75rem; color: #94a3b8; margin-top: 0.25rem; }
  .stat-sep { width: 1px; height: 2.5rem; background: rgba(255,255,255,0.1); }
  @media (max-width: 480px) {
    .stat-sep { display: none; }
    .stats-row { gap: 1.5rem; }
  }

  /* ── Year sections ── */
  .pub-list { display: flex; flex-direction: column; gap: 1.5rem; }

  .year-section { display: flex; flex-direction: column; gap: 0.75rem; }

  .year-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }
  .year-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .year-rule {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.07);
  }

  /* ── Publication card ── */
  .pub-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    align-items: flex-start;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .pub-card:hover {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.11);
  }

  .pub-body { flex: 1; min-width: 0; }

  .pub-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .type-badge {
    font-size: 0.62rem;
    font-weight: 700;
    color: #fff;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cite-badge {
    font-size: 0.68rem;
    font-weight: 700;
    color: #bfdbfe;
    background: rgba(59, 130, 246, 0.12);
    padding: 2px 10px;
    border-radius: 20px;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .pub-title {
    font-size: 1rem;
    font-weight: 600;
    color: #e2e8f0;
    line-height: 1.5;
    margin-bottom: 0.35rem;
  }
  .pub-title a { color: inherit; text-decoration: none; transition: color 0.15s; }
  .pub-title a:hover { color: #60a5fa; }

  .pub-authors { font-size: 0.82rem; color: #8094a8; margin-bottom: 0.2rem; line-height: 1.4; }
  .pub-venue   { font-size: 0.82rem; color: #7c9bc0; font-style: italic; line-height: 1.4; }

  .pub-abstract {
    font-size: 0.82rem;
    color: #7c8fa0;
    line-height: 1.6;
    margin-top: 0.5rem;
  }

  /* ── Links ── */
  .pub-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .pub-link {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 6px;
    text-decoration: none;
    text-align: center;
    letter-spacing: 0.04em;
    transition: all 0.15s ease;
    background: #2563eb;
    color: #fff;
    border: 1px solid #2563eb;
  }
  .pub-link:hover { background: #1d4ed8; }

  .pub-link-ghost {
    background: transparent;
    color: #94a3b8;
    border-color: rgba(255,255,255,0.12);
  }
  .pub-link-ghost:hover { background: rgba(255,255,255,0.06); color: #e2e8f0; }

  /* ── "N more" expander ── */
  .more-block { margin-top: 0.25rem; }

  .more-summary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: #3b82f6;
    cursor: pointer;
    list-style: none;
    user-select: none;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .more-summary::-webkit-details-marker { display: none; }
  .more-summary:hover { background: rgba(59,130,246,0.08); }

  .more-chevron {
    width: 0.9rem;
    height: 0.9rem;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .more-block[open] .more-chevron { transform: rotate(180deg); }

  .more-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .pub-card { flex-direction: column; gap: 0.75rem; }
    .pub-links { flex-direction: row; }
  }
</style>
