---
import { publications, scholarProfile } from '../data/publications.js';

// Sort by citations descending, then group by year (newest first)
const sorted = [...publications].sort((a, b) => b.citations - a.citations);

const byYear: Record<number, typeof publications> = {};
for (const pub of sorted) {
  if (!byYear[pub.year]) byYear[pub.year] = [];
  byYear[pub.year].push(pub);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const typeLabel: Record<string, string> = {
  journal: 'Journal',
  conference: 'Conference',
  workshop: 'Workshop',
  preprint: 'Preprint',
};

const typeColor: Record<string, string> = {
  journal: '#2563eb',
  conference: '#7c3aed',
  workshop: '#16a34a',
  preprint: '#ea580c',
};

const pubLink = (pub: any) => {
  if (pub.scholar_url?.includes('view_op=view_citation')) return pub.scholar_url;
  if (pub.doi?.includes('doi.org')) return pub.doi;
  return pub.scholar_url || null;
};
---

<section id="publications" class="arclab-section">
  <div class="pub-container arclab-container">

    <!-- Header -->
    <div class="pub-header text-center arclab-fade-in">
      <h2 class="arclab-heading-2 mb-2">Publications</h2>
      <p class="arclab-text max-w-2xl mx-auto">
        Research publications and academic contributions
      </p>
    </div>

    <!-- Scholar stats -->
    <div class="stats-row arclab-fade-in" style="animation-delay: 0.1s;">
      <div class="stat">
        <span class="stat-num">{scholarProfile.totalCitations}</span>
        <span class="stat-lbl">Citations</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">{scholarProfile.hIndex}</span>
        <span class="stat-lbl">h-index</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">{scholarProfile.i10Index}</span>
        <span class="stat-lbl">i10-index</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat">
        <span class="stat-num">{publications.length}</span>
        <span class="stat-lbl">Publications</span>
      </div>
    </div>

    <!-- Scrollable pub list -->
    <div class="pub-scroll arclab-fade-in" style="animation-delay: 0.2s;">
      <div class="pub-list">
        {years.map((year) => {
          const pubs = byYear[year];
          const top  = pubs[0];
          const rest = pubs.slice(1);
          return (
            <div class="year-section">

              <!-- Year divider — "N more" button lives here -->
              <div class="year-divider">
                <span class="year-label">{year}</span>
                <div class="year-rule"></div>
                {rest.length > 0 && (
                  <button class="more-btn" data-target={`more-${year}`}>
                    +{rest.length} more
                  </button>
                )}
              </div>

              <!-- Top pub — always visible -->
              <div class="pub-card">
                <div class="pub-body">
                  <div class="pub-meta">
                    <span class="type-badge" style={`background:${typeColor[top.type] ?? '#475569'}`}>
                      {typeLabel[top.type] ?? top.type}
                    </span>
                    {top.citations > 0 && (
                      <span class="cite-badge">
                        {top.citations} {top.citations === 1 ? 'citation' : 'citations'}
                      </span>
                    )}
                  </div>
                  <h4 class="pub-title">
                    {pubLink(top) ? (
                      <a href={pubLink(top)} target="_blank" rel="noopener noreferrer">
                        {top.title}
                      </a>
                    ) : top.title}
                  </h4>
                  <p class="pub-authors">{top.authors.join(', ')}</p>
                  <p class="pub-venue">{top.venue}</p>
                  {top.abstract && (
                    <p class="pub-abstract">
                      {top.abstract.length > 220 ? top.abstract.slice(0, 220) + '…' : top.abstract}
                    </p>
                  )}
                </div>
                <div class="pub-links">
                  {top.pdfUrl && (
                    <a href={top.pdfUrl} target="_blank" rel="noopener noreferrer" class="pub-link">PDF</a>
                  )}
                </div>
              </div>

              <!-- Extra pubs — hidden by default, toggled by year-divider button -->
              {rest.length > 0 && (
                <div class="more-inner" id={`more-${year}`} hidden>
                  {rest.map(pub => (
                    <div class="pub-card">
                      <div class="pub-body">
                        <div class="pub-meta">
                          <span class="type-badge" style={`background:${typeColor[pub.type] ?? '#475569'}`}>
                            {typeLabel[pub.type] ?? pub.type}
                          </span>
                          {pub.citations > 0 && (
                            <span class="cite-badge">
                              {pub.citations} {pub.citations === 1 ? 'citation' : 'citations'}
                            </span>
                          )}
                        </div>
                        <h4 class="pub-title">
                          {pubLink(pub) ? (
                            <a href={pubLink(pub)} target="_blank" rel="noopener noreferrer">
                              {pub.title}
                            </a>
                          ) : pub.title}
                        </h4>
                        <p class="pub-authors">{pub.authors.join(', ')}</p>
                        <p class="pub-venue">{pub.venue}</p>
                        {pub.abstract && (
                          <p class="pub-abstract">
                            {pub.abstract.length > 220 ? pub.abstract.slice(0, 220) + '…' : pub.abstract}
                          </p>
                        )}
                      </div>
                      <div class="pub-links">
                        {pub.pdfUrl && (
                          <a href={pub.pdfUrl} target="_blank" rel="noopener noreferrer" class="pub-link">PDF</a>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              )}

            </div>
          );
        })}
      </div>
    </div>

    <!-- Scholar link -->
    <div class="pub-footer text-center">
      <a
        href={scholarProfile.profileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="arclab-button-secondary text-sm inline-flex items-center gap-2"
      >
        <i class="fas fa-graduation-cap"></i>
        View full profile on Google Scholar
      </a>
    </div>

  </div>
</section>

<!-- ── Publication modal overlay ── -->
<div id="pub-modal" class="pub-modal" role="dialog" aria-modal="true" aria-label="More publications" hidden>
  <div class="pub-modal-backdrop"></div>
  <div class="pub-modal-panel">
    <div class="pub-modal-head">
      <span class="pub-modal-year"></span>
      <button class="pub-modal-close" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="pub-modal-list"></div>
  </div>
</div>

<style>
  /* ── Desktop: container fills the fp-mode section (inset:0) ── */
  @media (min-width: 768px) {
    .pub-container {
      flex: 1 1 0% !important;
      margin-top: 0 !important;
      margin-bottom: 0 !important;
      min-height: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .pub-scroll {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      overflow-x: hidden;
      padding-right: 0.375rem;
    }
    .pub-scroll::-webkit-scrollbar { width: 4px; }
    .pub-scroll::-webkit-scrollbar-track { background: transparent; }
    .pub-scroll::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.15);
      border-radius: 2px;
    }
    .pub-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.28); }

    .pub-footer {
      flex-shrink: 0;
      padding-top: 0.75rem;
      border-top: 1px solid rgba(255,255,255,0.07);
    }
  }

  /* ── Fixed parts ── */
  .pub-header { flex-shrink: 0; padding-bottom: 0.25rem; }

  /* ── Stats ── */
  .stats-row {
    flex-shrink: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    padding: 0.35rem 0 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    margin-bottom: 0.5rem;
  }
  .stat { text-align: center; }
  .stat-num { display: block; font-size: 1.75rem; font-weight: 700; color: #fff; line-height: 1; }
  .stat-lbl { display: block; font-size: 0.7rem; color: #94a3b8; margin-top: 0.2rem; }
  .stat-sep { width: 1px; height: 2rem; background: rgba(255,255,255,0.1); }

  /* ── Year sections ── */
  .pub-list { display: flex; flex-direction: column; gap: 0.875rem; padding-bottom: 0.25rem; }

  .year-section { display: flex; flex-direction: column; gap: 0.5rem; }

  .year-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0;
  }
  .year-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .year-rule {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.07);
  }

  /* ── Publication card ── */
  .pub-card {
    display: flex;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    align-items: flex-start;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .pub-card:hover {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.11);
  }

  .pub-body { flex: 1; min-width: 0; }

  .pub-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .type-badge {
    font-size: 0.62rem;
    font-weight: 700;
    color: #fff;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cite-badge {
    font-size: 0.68rem;
    font-weight: 700;
    color: #bfdbfe;
    background: rgba(59, 130, 246, 0.12);
    padding: 2px 10px;
    border-radius: 20px;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .pub-title {
    font-size: 1rem;
    font-weight: 600;
    color: #e2e8f0;
    line-height: 1.5;
    margin-bottom: 0.35rem;
  }
  .pub-title a { color: inherit; text-decoration: none; transition: color 0.15s; }
  .pub-title a:hover { color: #60a5fa; }

  .pub-authors { font-size: 0.82rem; color: #8094a8; margin-bottom: 0.2rem; line-height: 1.4; }
  .pub-venue   { font-size: 0.82rem; color: #7c9bc0; font-style: italic; line-height: 1.4; }

  /* 2-line preview on desktop — cards are wide enough */
  .pub-abstract {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.78rem;
    color: #7c8fa0;
    line-height: 1.55;
    margin-top: 0.3rem;
  }

  /* ── Links ── */
  .pub-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .pub-link {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 6px;
    text-decoration: none;
    text-align: center;
    letter-spacing: 0.04em;
    transition: all 0.15s ease;
    background: #2563eb;
    color: #fff;
    border: 1px solid #2563eb;
  }
  .pub-link:hover { background: #1d4ed8; }

  /* ── "N more" toggle button (lives in year-divider) ── */
  .more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #3b82f6;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.2rem 0.5rem;
    border-radius: 5px;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .more-btn:hover { background: rgba(59,130,246,0.1); }

  .more-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .more-inner[hidden] { display: none; }

  /* ── Modal overlay ── */
  .pub-modal {
    position: fixed;
    inset: 0;
    z-index: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(0.75rem, 4vw, 2.5rem);
  }
  .pub-modal[hidden] { display: none; }

  .pub-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(6, 10, 20, 0.82);
    animation: fade-in 0.15s ease forwards;
  }

  .pub-modal-panel {
    position: relative;
    z-index: 1;
    background: #0f172a;
    border: 1px solid rgba(255,255,255,0.13);
    border-radius: 16px;
    width: min(680px, 100%);
    max-height: min(82vh, 720px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,0.6);
    animation: fade-in 0.15s ease forwards;
    will-change: opacity;
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .pub-modal-panel.closing {
    animation: fade-out 0.12s ease forwards;
  }
  @keyframes fade-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  .pub-modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }
  .pub-modal-year {
    font-size: 0.75rem;
    font-weight: 700;
    color: #64748b;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .pub-modal-close {
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    cursor: pointer;
    color: #94a3b8;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .pub-modal-close:hover { background: rgba(255,255,255,0.12); color: #e2e8f0; }
  .pub-modal-close svg { width: 0.875rem; height: 0.875rem; }

  .pub-modal-list {
    flex: 1;
    overflow-y: auto;
    padding: 0.875rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .pub-modal-list::-webkit-scrollbar { width: 4px; }
  .pub-modal-list::-webkit-scrollbar-track { background: transparent; }
  .pub-modal-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 2px; }

  /* Cards inside modal get full abstract */
  .pub-modal-list .pub-abstract {
    display: block !important;
    -webkit-line-clamp: unset !important;
    overflow: visible !important;
    font-size: 0.8rem;
    color: #7c8fa0;
    line-height: 1.6;
    margin-top: 0.4rem;
  }
  .pub-modal-list .pub-card {
    padding: 0.875rem 1rem;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .stat-sep { display: none; }
    .stats-row { gap: 1.5rem; }
    .stat-num { font-size: 2rem; }
    .pub-card { flex-direction: column; gap: 0.75rem; padding: 1.25rem 1.5rem; }
    .pub-links { flex-direction: row; }
    .pub-abstract {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      font-size: 0.82rem;
      color: #7c8fa0;
      line-height: 1.6;
      margin-top: 0.45rem;
    }
  }
</style>

<script>
  const modal      = document.getElementById('pub-modal') as HTMLElement;
  const modalPanel = modal.querySelector('.pub-modal-panel') as HTMLElement;
  const modalYear  = modal.querySelector('.pub-modal-year') as HTMLElement;
  const modalList  = modal.querySelector('.pub-modal-list') as HTMLElement;
  const closeBtn   = modal.querySelector('.pub-modal-close') as HTMLButtonElement;
  const backdrop   = modal.querySelector('.pub-modal-backdrop') as HTMLElement;

  function openModal() {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    modalPanel.classList.remove('closing');
  }

  function closeModal() {
    modalPanel.classList.add('closing');
    modalPanel.addEventListener('animationend', () => {
      modal.hidden = true;
      document.body.style.overflow = '';
      modalPanel.classList.remove('closing');
    }, { once: true });
  }

  // Open modal from "N more" button
  document.querySelectorAll<HTMLButtonElement>('.more-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const section  = btn.closest('.year-section') as HTMLElement;
      const yearText = section.querySelector('.year-label')!.textContent!;
      const targetId = btn.dataset.target!;
      const moreInner = document.getElementById(targetId);

      // Set year label
      modalYear.textContent = yearText + ' — All Publications';

      // Populate list: top pub + extra pubs
      modalList.innerHTML = '';
      const topCard = section.querySelector('.pub-card')!.cloneNode(true) as HTMLElement;
      modalList.appendChild(topCard);
      if (moreInner) {
        moreInner.querySelectorAll('.pub-card').forEach(card => {
          modalList.appendChild(card.cloneNode(true));
        });
      }

      openModal();
      // Scroll to top
      modalList.scrollTop = 0;
    });
  });

  // Close on backdrop click or close button
  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });
</script>
