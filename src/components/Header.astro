---
---

<header class="fixed top-0 w-full z-50 header-bar">
  <nav class="arclab-container">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="#hero" class="flex items-center gap-2.5 group nav-home">
        <img
          src="/logos/carrusk_logo_monkey.jpeg"
          alt="AC"
          class="w-7 h-7 rounded-full opacity-90 group-hover:opacity-100 transition-opacity"
        />
        <span class="text-sm font-medium text-white/80 group-hover:text-white transition-colors tracking-wide">
          Alejandro Carrasco
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-7">
        <a href="#hero"         class="nav-link" data-section="hero">Home</a>
        <a href="#publications" class="nav-link" data-section="publications">Publications</a>
        <a href="#projects"     class="nav-link" data-section="projects">Projects</a>
        <a href="#achievements" class="nav-link" data-section="achievements">Awards</a>
        <a href="#affiliations" class="nav-link" data-section="affiliations">Affiliations</a>
        <a href="#contact"      class="nav-link" data-section="contact">Contact</a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 rounded-md text-white/50 hover:text-white hover:bg-white/5 transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-white/5 mt-1 pt-3">
      <div class="flex flex-col gap-1">
        <a href="#hero"         class="mobile-nav-link" data-section="hero">Home</a>
        <a href="#publications" class="mobile-nav-link" data-section="publications">Publications</a>
        <a href="#projects"     class="mobile-nav-link" data-section="projects">Projects</a>
        <a href="#achievements" class="mobile-nav-link" data-section="achievements">Awards</a>
        <a href="#affiliations" class="mobile-nav-link" data-section="affiliations">Affiliations</a>
        <a href="#contact"      class="mobile-nav-link" data-section="contact">Contact</a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile toggle
  document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('hidden');
    });
  });

  // Active section highlight
  function setActive(sectionId: string) {
    document.querySelectorAll('.nav-link, .mobile-nav-link').forEach(link => {
      const matches = (link as HTMLElement).dataset.section === sectionId;
      link.classList.toggle('nav-link-active', matches);
    });
  }

  // Listen for fullpage section changes
  document.addEventListener('fp-section-change', (e) => {
    setActive((e as CustomEvent).detail.id);
  });

  // Fallback: IntersectionObserver for non-fp mode only.
  // Delay with rAF so Layout.astro's DOMContentLoaded (which sets fp-mode) runs first.
  requestAnimationFrame(() => {
    if (document.body.classList.contains('fp-mode')) return;
    const sections = document.querySelectorAll('main > section[id]');
    if (sections.length > 0) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) setActive(entry.target.id);
        });
      }, { threshold: 0.4 });
      sections.forEach(s => obs.observe(s));
    }
  });
</script>

<style>
  .header-bar {
    background: rgba(15, 23, 42, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 2px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.6);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .nav-link.nav-link-active {
    color: rgba(255, 255, 255, 0.95);
  }

  .nav-link.nav-link-active::after {
    transform: scaleX(1);
  }

  .mobile-nav-link {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding: 0.5rem 0.25rem;
    transition: color 0.15s ease;
    display: block;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.nav-link-active {
    color: white;
  }
</style>
