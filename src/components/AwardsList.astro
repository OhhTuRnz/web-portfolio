---
import { awards } from '../data/awards.js';

// Newest first
const sorted = [...awards].sort((a, b) => b.year - a.year);
const years  = [...new Set(sorted.map((a: any) => a.year))];

// Flat list: year markers interleaved with awards
const flatItems: Array<{ type: 'year'; year: number } | { type: 'award'; award: any; idx: number }> = [];
let awardCount = 0;
let prevYear: number | null = null;
for (const award of sorted) {
  if (award.year !== prevYear) {
    flatItems.push({ type: 'year', year: award.year });
    prevYear = award.year;
  }
  flatItems.push({ type: 'award', award, idx: awardCount++ });
}

const categoryBadge: Record<string, string> = {
  research:   'bg-yellow-500/15 text-yellow-300 border border-yellow-500/30',
  fellowship: 'bg-blue-500/15 text-blue-300 border border-blue-500/30',
  funding:    'bg-green-500/15 text-green-300 border border-green-500/30',
  academic:   'bg-indigo-500/15 text-indigo-300 border border-indigo-500/30',
};

const categoryDot: Record<string, string> = {
  research:   'dot-yellow',
  fellowship: 'dot-blue',
  funding:    'dot-green',
  academic:   'dot-indigo',
};
---

<section id="achievements" class="arclab-section fp-slide-section">
  <div class="arclab-container awards-outer">

    <!-- Section header -->
    <div class="awards-header text-center arclab-fade-in">
      <h2 class="arclab-heading-2 mb-1">Awards & Recognition</h2>
      <p class="arclab-text text-sm opacity-50">Scroll to explore →</p>
    </div>

    <!-- Horizontal timeline -->
    <div class="tl-viewport fp-scroll-x">
      <div class="tl-track">

        <!-- The line -->
        <div class="tl-hline" aria-hidden="true"></div>

        {flatItems.map((item) => {
          if (item.type === 'year') {
            return (
              <div class="tl-year-sep" data-year={item.year}>
                <div class="tl-year-tick" aria-hidden="true"></div>
                <span class="tl-year-label">{item.year}</span>
              </div>
            );
          }

          const { award, idx } = item;
          const isAbove = idx % 2 === 0;
          const dotCls   = categoryDot[award.category]  ?? 'dot-indigo';
          const badgeCls = categoryBadge[award.category] ?? categoryBadge.academic;

          return (
            <div class="tl-col">
              {/* Top half */}
              <div class="tl-half tl-top">
                {isAbove && (
                  <a href={award.link} target="_blank" rel="noopener noreferrer"
                     class="award-card group">
                    <span class={`badge ${badgeCls}`}>{award.category}</span>
                    <h4 class="card-title group-hover:text-blue-300 transition-colors">
                      {award.title}
                    </h4>
                    <p class="card-org">{award.organization}</p>
                  </a>
                )}
              </div>

              {/* Dot on the line */}
              <div class={`tl-dot ${dotCls}`}>{award.icon}</div>

              {/* Bottom half */}
              <div class="tl-half tl-bot">
                {!isAbove && (
                  <a href={award.link} target="_blank" rel="noopener noreferrer"
                     class="award-card group">
                    <span class={`badge ${badgeCls}`}>{award.category}</span>
                    <h4 class="card-title group-hover:text-blue-300 transition-colors">
                      {award.title}
                    </h4>
                    <p class="card-org">{award.organization}</p>
                  </a>
                )}
              </div>
            </div>
          );
        })}

      </div>
    </div>

    <!-- Year pills -->
    <div class="year-indicator">
      {years.map((year: number, i: number) => (
        <button class={`year-btn ${i === 0 ? 'active' : ''}`} data-year={year}>
          {year}
        </button>
      ))}
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector<HTMLElement>('#achievements');
    if (!section) return;
    const vp = section.querySelector<HTMLElement>('.fp-scroll-x');
    if (!vp) return;

    function revealVisible() {
      const left  = vp!.scrollLeft - 160;
      const right = vp!.scrollLeft + vp!.clientWidth + 160;
      section!.querySelectorAll<HTMLElement>('.tl-col').forEach(col => {
        if (col.offsetLeft + col.offsetWidth > left && col.offsetLeft < right) {
          col.querySelectorAll('.award-card').forEach(c => c.classList.add('card-visible'));
        }
      });
    }

    function updateActiveYear() {
      const center = vp!.scrollLeft + vp!.clientWidth / 2;
      let active: string | null = null;
      section!.querySelectorAll<HTMLElement>('.tl-year-sep').forEach(sep => {
        if (sep.offsetLeft <= center) active = sep.dataset.year ?? null;
      });
      section!.querySelectorAll('.year-btn').forEach(btn =>
        btn.classList.toggle('active', (btn as HTMLElement).dataset.year === String(active))
      );
    }

    let revealTimer: ReturnType<typeof setTimeout>;
    vp.addEventListener('scroll', () => {
      updateActiveYear();
      clearTimeout(revealTimer);
      revealTimer = setTimeout(revealVisible, 80);
    }, { passive: true });

    section.querySelectorAll<HTMLButtonElement>('.year-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const sep = section!.querySelector<HTMLElement>(`.tl-year-sep[data-year="${btn.dataset.year}"]`);
        if (sep) {
          const target = sep.offsetLeft - vp!.clientWidth * 0.12;
          vp!.scrollTo({ left: Math.max(0, target), behavior: 'smooth' });
        }
      });
    });

    section.addEventListener('fp-activate', () => { revealVisible(); updateActiveYear(); });

    new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { revealVisible(); updateActiveYear(); }
    }, { threshold: 0.1 }).observe(section);
  });
</script>

<style>
  /* ── Outer shell ── */
  .awards-outer {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding-top: 1rem;
    padding-bottom: 0.75rem;
  }

  .awards-header { flex-shrink: 0; margin-bottom: 0.25rem; }

  /* ── Scrollable viewport ── */
  .tl-viewport {
    flex: 1;
    min-height: 0;
    overflow-x: scroll;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .tl-viewport::-webkit-scrollbar { display: none; }

  /* ── Track ── */
  .tl-track {
    display: flex;
    align-items: stretch;
    height: 100%;
    min-width: max-content;
    padding: 0 12vw;
    position: relative;
  }

  /* ── Horizontal centre line ── */
  .tl-hline {
    position: absolute;
    left: 0; right: 0;
    top: 50%;
    height: 1px;
    transform: translateY(-50%);
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(255,255,255,0.10) 5%,
      rgba(255,255,255,0.18) 12%,
      rgba(255,255,255,0.18) 88%,
      rgba(255,255,255,0.10) 95%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* ── Year separator ── */
  .tl-year-sep {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 72px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .tl-year-tick {
    width: 1px;
    height: 14px;
    background: rgba(255,255,255,0.28);
    border-radius: 1px;
    margin-bottom: 6px;
  }

  .tl-year-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.38);
    white-space: nowrap;
  }

  /* ── Award column ── */
  .tl-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 250px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .tl-half {
    flex: 1;
    width: 100%;
    display: flex;
    padding: 0 0.5rem;
  }

  .tl-top { align-items: flex-end;   padding-bottom: 0.75rem; }
  .tl-bot { align-items: flex-start; padding-top: 0.75rem; }

  /* ── Dot ── */
  .tl-dot {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
    border: 2px solid;
    position: relative;
    z-index: 2;
  }

  .dot-yellow { background: rgba(234,179,8,0.12);  border-color: rgba(234,179,8,0.40); }
  .dot-blue   { background: rgba(59,130,246,0.12); border-color: rgba(59,130,246,0.40); }
  .dot-green  { background: rgba(34,197,94,0.12);  border-color: rgba(34,197,94,0.40); }
  .dot-indigo { background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.40); }

  /* ── Card ── */
  .award-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.875rem 1rem;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    background: rgba(255,255,255,0.03);
    text-decoration: none;
    width: 100%;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease, transform 0.35s ease,
                background 0.15s ease, border-color 0.15s ease;
  }
  .award-card.card-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .award-card:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(59,130,246,0.28);
  }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 9999px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: capitalize;
    margin-bottom: 0.15rem;
    width: fit-content;
  }

  .card-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #e2e8f0;
    line-height: 1.4;
  }

  .card-org {
    font-size: 0.7rem;
    color: #64748b;
    line-height: 1.3;
    margin-top: 0.1rem;
  }

  /* ── Year pills ── */
  .year-indicator {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding-top: 0.75rem;
  }

  .year-btn {
    padding: 0.2rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    border: 1px solid rgba(255,255,255,0.12);
    background: transparent;
    color: rgba(255,255,255,0.3);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .year-btn.active {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.9);
    border-color: rgba(255,255,255,0.28);
  }
  .year-btn:hover:not(.active) { color: rgba(255,255,255,0.55); }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .tl-track { padding: 0 4vw; }
    .tl-col   { width: 190px; }
    .tl-year-sep { width: 52px; }
    .tl-dot   { width: 34px; height: 34px; font-size: 0.9rem; }
    .card-title { font-size: 0.73rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .award-card { opacity: 1; transform: none; transition: none; }
  }
</style>
