---
import { awards, getAwardsByYear } from '../data/awards.js';

const awardsByYear = getAwardsByYear();
const years = Object.keys(awardsByYear).sort((a, b) => Number(b) - Number(a));

const categoryGradient = {
  research:   'from-yellow-500 to-orange-500',
  fellowship: 'from-blue-500 to-purple-500',
  funding:    'from-green-500 to-teal-500',
  academic:   'from-indigo-500 to-purple-500'
};

const categoryBadge = {
  research:   'bg-yellow-500/15 text-yellow-300 border border-yellow-500/30',
  fellowship: 'bg-blue-500/15 text-blue-300 border border-blue-500/30',
  funding:    'bg-green-500/15 text-green-300 border border-green-500/30',
  academic:   'bg-indigo-500/15 text-indigo-300 border border-indigo-500/30'
};

const dotColor = {
  research:   'bg-yellow-500',
  fellowship: 'bg-blue-500',
  funding:    'bg-green-500',
  academic:   'bg-indigo-500'
};

const dotRing = {
  research:   'bg-yellow-500/40',
  fellowship: 'bg-blue-500/40',
  funding:    'bg-green-500/40',
  academic:   'bg-indigo-500/40'
};
---

<section id="achievements" class="arclab-section">
  <div class="arclab-container">
    <div class="text-center mb-16 arclab-fade-in">
      <h2 class="arclab-heading-2">Awards & Recognition</h2>
    </div>

    <!-- Timeline -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Vertical line -->
      <div class="timeline-line absolute left-1/2 -translate-x-1/2 w-0.5 h-full bg-gradient-to-b from-blue-500 via-purple-500 to-cyan-500 rounded-full z-0"></div>

      <div class="space-y-10">
        {years.map((year) => (
          <div class="year-group">
            <!-- Year header with flanking rules -->
            <div class="flex items-center justify-center mb-8 relative z-20">
              <div class="flex-1 h-px bg-gradient-to-r from-transparent to-white/10"></div>
              <span class="mx-4 px-5 py-1.5 rounded-full bg-slate-800 border border-white/10 text-white font-bold text-lg tracking-wide shadow-lg">
                {year}
              </span>
              <div class="flex-1 h-px bg-gradient-to-l from-transparent to-white/10"></div>
            </div>

            {awardsByYear[year].map((award, index) => (
              <div class={`award-item flex items-center ${index % 2 === 0 ? 'flex-row' : 'flex-row-reverse'} mb-8`}>

                <!-- Card -->
                <div class={`w-5/12 ${index % 2 === 0 ? 'pr-10' : 'pl-10'}`}>
                  <a
                    href={award.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="award-card group block rounded-2xl p-5 border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] transition-all duration-300 hover:border-blue-500/40 hover:shadow-[0_0_28px_rgba(59,130,246,0.1)]"
                  >
                    <div class="flex items-start gap-4">
                      <!-- Icon circle -->
                      <div class={`flex-shrink-0 w-14 h-14 rounded-full flex items-center justify-center text-2xl shadow-lg bg-gradient-to-br ${categoryGradient[award.category] || categoryGradient.academic}`}>
                        {award.icon}
                      </div>

                      <div class="flex-1 min-w-0">
                        <!-- Category badge -->
                        <span class={`inline-block mb-2 px-2.5 py-0.5 rounded-full text-xs font-medium capitalize ${categoryBadge[award.category] || categoryBadge.academic}`}>
                          {award.category}
                        </span>
                        <h4 class="text-base font-semibold text-white leading-snug mb-1 group-hover:text-blue-300 transition-colors">
                          {award.title}
                        </h4>
                        <p class="text-sm text-slate-400">{award.organization}</p>
                      </div>

                      <!-- External link arrow — always visible -->
                      <svg
                        class="w-4 h-4 text-slate-600 group-hover:text-blue-400 flex-shrink-0 transition-colors mt-1"
                        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                      >
                        <line x1="7" y1="17" x2="17" y2="7"></line>
                        <polyline points="7 7 17 7 17 17"></polyline>
                      </svg>
                    </div>
                  </a>
                </div>

                <!-- Timeline dot -->
                <div class="w-2/12 flex justify-center">
                  <div class="relative flex items-center justify-center w-10 h-10 z-10">
                    <div class={`absolute inset-0 rounded-full animate-ping opacity-20 ${dotRing[award.category] || dotRing.academic}`}></div>
                    <div class={`w-5 h-5 rounded-full border-4 border-slate-900 shadow-lg ${dotColor[award.category] || dotColor.academic}`}></div>
                  </div>
                </div>

                <!-- Spacer / hover image preview (opposite side) -->
                <div class="w-5/12 flex items-center justify-center">
                  {award.image && (
                    <div class="award-preview-wrap">
                      <img
                        src={award.image}
                        alt={award.title}
                        class="award-preview-img"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('award-visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.award-item').forEach(el => observer.observe(el));
  });
</script>

<style>
  .award-item {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .award-item.award-visible {
    opacity: 1;
    transform: none;
  }

  .timeline-line {
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .timeline-line {
      display: none;
    }

    .award-item {
      flex-direction: column !important;
      align-items: stretch;
      position: relative;
      z-index: 1;
    }

    .award-item > div:first-child {
      width: 100% !important;
      padding-right: 0 !important;
      padding-left: 0 !important;
    }

    /* Hide dot column and spacer on mobile */
    .award-item > div:nth-child(2),
    .award-item > div:last-child {
      display: none;
    }
  }

  /* ── Award hover image preview ── */
  .award-preview-wrap {
    width: 100%;
    max-width: 260px;
    border-radius: 12px;
    overflow: hidden;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.35s ease, transform 0.35s ease;
    pointer-events: none;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .award-preview-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .award-item:has(.award-card:hover) .award-preview-wrap {
    opacity: 1;
    transform: scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .award-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
    [class*="animate-ping"] {
      animation: none;
    }
  }
</style>
