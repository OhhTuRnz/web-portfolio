---
---

<div id="star-canvas" class="fixed inset-0 pointer-events-none z-0"></div>

<script>
  class StarParticleSystem {
    constructor() {
      this.canvas = document.createElement('canvas');
      this.ctx = this.canvas.getContext('2d');
      this.stars = [];
      this.mouse = { x: -9999, y: -9999 };
      this.animationId = null;
      this._lastFrame = 0;
      this._onResize = () => this.resize();
      this._onMouseMove = (e) => { this.mouse.x = e.clientX; this.mouse.y = e.clientY; };

      this.init();
    }

    hasGPU() {
      try {
        const c = document.createElement('canvas');
        return !!(c.getContext('webgl') || c.getContext('experimental-webgl'));
      } catch { return false; }
    }

    renderStatic(container) {
      if (!document.getElementById('static-particle-style')) {
        const style = document.createElement('style');
        style.id = 'static-particle-style';
        style.textContent = `
          @keyframes dotPulse {
            0%, 100% { opacity: 0.05; transform: scale(0.85); }
            50% { opacity: var(--max-op, 0.35); transform: scale(1); }
          }
          .static-dot {
            position: absolute; border-radius: 50%;
            animation: dotPulse var(--dur) ease-in-out infinite var(--delay);
          }
        `;
        document.head.appendChild(style);
      }
      container.style.cssText = 'position:fixed;inset:0;overflow:hidden;pointer-events:none;';
      for (let i = 0; i < 30; i++) {
        const dot = document.createElement('div');
        dot.className = 'static-dot';
        const size = 0.5 + Math.random() * 2;
        const hue  = 200 + Math.random() * 60;
        dot.style.cssText = `
          left:${Math.random()*100}%; top:${Math.random()*100}%;
          width:${size}px; height:${size}px;
          background:hsl(${hue},70%,85%);
          --dur:${3 + Math.random()*5}s;
          --delay:${-(Math.random()*5)}s;
          --max-op:${0.3 + Math.random()*0.45};
        `;
        container.appendChild(dot);
      }
    }

    init() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const container = document.getElementById('star-canvas');
      if (!container) return;

      if (!this.hasGPU()) {
        this.renderStatic(container);
        return;
      }

      container.appendChild(this.canvas);

      this.resize();
      this.createStars();
      this.animationId = requestAnimationFrame((ts) => this.animate(ts));

      window.addEventListener('resize', this._onResize);
      window.addEventListener('mousemove', this._onMouseMove, { passive: true });
    }

    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
      this.stars = [];
      this.createStars();
    }

    createStars() {
      const MAX_STARS = 60;
      const starCount = Math.min(
        Math.floor((this.canvas.width * this.canvas.height) / 12000),
        MAX_STARS
      );

      for (let i = 0; i < starCount; i++) {
        this.stars.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
          size: Math.random() * 2 + 0.5,
          opacity: Math.random() * 0.8 + 0.2,
          twinkleSpeed: 0.01 + Math.random() * 0.02,
          hue: 200 + Math.random() * 60,
          brightness: 70 + Math.random() * 25
        });
      }
    }

    animate(ts = 0) {
      this.animationId = requestAnimationFrame((t) => this.animate(t));

      // Cap at 60fps
      if (ts - this._lastFrame < 16.67) return;
      this._lastFrame = ts;

      const ctx = this.ctx;
      ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

      const time = ts * 0.001;

      this.stars.forEach((s, i) => {
        s.x += s.vx;
        s.y += s.vy;

        if (s.x < 0) s.x = this.canvas.width;
        if (s.x > this.canvas.width) s.x = 0;
        if (s.y < 0) s.y = this.canvas.height;
        if (s.y > this.canvas.height) s.y = 0;

        // Mouse repulsion (avoid sqrt when out of range)
        const dx = this.mouse.x - s.x;
        const dy = this.mouse.y - s.y;
        const dist2 = dx * dx + dy * dy;
        if (dist2 < 10000) { // 100²
          const force = (100 - Math.sqrt(dist2)) / 100;
          s.x -= dx * force * 0.01;
          s.y -= dy * force * 0.01;
        }

        // Twinkle with solid fill — no per-frame gradient
        const twinkle = Math.sin(time * s.twinkleSpeed * 100 + i) * 0.3 + 0.7;
        const alpha = s.opacity * twinkle;

        ctx.beginPath();
        ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${s.hue}, 70%, ${s.brightness}%, ${alpha})`;
        ctx.fill();

        // Subtle glow for larger stars (single extra circle, no gradient)
        if (s.size > 1.5) {
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.size * 2, 0, Math.PI * 2);
          ctx.fillStyle = `hsla(${s.hue}, 70%, ${s.brightness}%, ${alpha * 0.15})`;
          ctx.fill();
        }
      });
    }

    destroy() {
      if (this.animationId) cancelAnimationFrame(this.animationId);
      window.removeEventListener('resize', this._onResize);
      window.removeEventListener('mousemove', this._onMouseMove);
      if (this.canvas.parentNode) this.canvas.parentNode.removeChild(this.canvas);
    }
  }

  let starSystem = null;

  document.addEventListener('DOMContentLoaded', () => {
    starSystem = new StarParticleSystem();
  });

  window.addEventListener('beforeunload', () => {
    if (starSystem) starSystem.destroy();
  });
</script>
