---
import StarParticleBackground from './StarParticleBackground.astro';
---

<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden pt-28 md:pt-16">
  <StarParticleBackground />
  
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900/95 via-slate-800/90 to-slate-900/95 z-10"></div>
  
  <div class="arclab-container relative z-20">
    <div class="max-w-7xl mx-auto">
      <!-- Professional links header -->
      <div class="text-center mb-20 hero-header">
        <div class="flex justify-center items-center gap-3 md:gap-8 mb-12">
          <a href="/assets/CarruskCV.pdf" target="_blank" class="arclab-button-secondary hero-button">
            <i class="fas fa-file-pdf"></i>CV
          </a>
          <a href="https://scholar.google.com/citations?user=6KamS70AAAAJ&hl=en" target="_blank" class="arclab-button-secondary hero-button">
            <i class="fas fa-graduation-cap"></i>Google Scholar
          </a>
          <a href="https://aeroastro.mit.edu/arclab/" target="_blank" class="arclab-button hero-button">
            <i class="fas fa-university"></i>MIT ARC Lab
          </a>
        </div>
      </div>
      
      <!-- Main content grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-20 items-center">
        <!-- Text content -->
        <div class="lg:col-span-2 space-y-10 hero-content order-2 lg:order-1">
          <div class="space-y-8">
            <h1 class="hero-title">
              <span class="block hero-name">Alejandro Carrasco</span>
              <span class="block text-xl lg:text-2xl arclab-text font-light mt-6 hero-subtitle">
                Agentic AI & Autonomous Robotics
              </span>
            </h1>
          </div>
          
          <p class="text-white max-w-3xl leading-relaxed hero-description" style="font-family: 'Electrolize', monospace; font-size: 1.2rem;">
            Developing intelligent systems at the intersection of artificial intelligence and robotics, with a focus on
            <span class="text-green-400">Large Language Models</span>,
            <span class="text-green-400">autonomous agents</span>, and
            <span class="text-green-400">multi-embodiment robotics</span>
            for cutting-edge advancements in space exploration and technology.
          </p>
          
          <!-- Social Links -->
          <div class="flex justify-center space-x-6 hero-social">
            <a href="https://github.com/OhhTuRnz" target="_blank" class="social-link">
              <i class="fab fa-github text-lg"></i>
            </a>
            <a href="https://linkedin.com/in/carrusk" target="_blank" class="social-link">
              <i class="fab fa-linkedin text-lg"></i>
            </a>
            <a href="https://x.com/OhhTuRnz123" target="_blank" class="social-link">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a href="#contact" class="social-link">
              <i class="fas fa-envelope text-lg"></i>
            </a>
          </div>
        </div>
        
        <!-- Professional Photo with Animated Violet Contour -->
        <div class="flex justify-center lg:justify-end hero-image-section order-1 lg:order-2">
          <div class="relative profile-image-wrapper">
            <!-- Animated rotating violet contour - appears during startup -->
            <div class="rotating-contour startup-animation"></div>
            <div class="rotating-contour-secondary startup-animation"></div>
            
            <!-- Hover glow effect - only on hover -->
            <div class="hover-glow-effect"></div>
            
            <picture>
              <source srcset="/assets/images/carrusk_zen.webp" type="image/webp" />
              <img
                src="/assets/images/carrusk_zen.png"
                alt="Alejandro Carrasco"
                class="profile-image w-80 h-80 rounded-full object-cover relative z-10
                       shadow-2xl"
                loading="eager"
              />
            </picture>
            
            <!-- Loading animation overlay -->
            <div class="loading-overlay">
              <div class="loading-spinner"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator - centered on full section width -->
  <div class="absolute inset-x-0 bottom-8 flex justify-center z-30">
    <a href="#publications" class="scroll-link group">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
      <span class="scroll-text group-hover:text-violet-400 transition-colors">Scroll to explore</span>
    </a>
  </div>
</section>

<style>
  /* ── Custom Fonts ── */
  @font-face {
    font-family: 'Roinert';
    src: url('/fonts/RoinertOneRoundSqV2-9MpLy.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Roinert';
    src: url('/fonts/RoinertOneRoundSqV2Italic-yYAvm.ttf') format('truetype');
    font-weight: normal;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'PixelatedElegance';
    src: url('/fonts/PixelatedEleganceRegular-ovawB.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'SimpanseX';
    src: url('/fonts/SimpanseXItalic-DY533.otf') format('opentype');
    font-weight: normal;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: 'Iconoplastic';
    src: url('/fonts/Iconoplastic-BLlZx.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Iconoplastic';
    src: url('/fonts/IconoplasticItalic-8Omlg.otf') format('opentype');
    font-weight: normal;
    font-style: italic;
    font-display: swap;
  }

  /* Hero Section Animations */
  .hero-header {
    animation: fadeInDown 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(-30px);
  }
  
  .hero-button {
    transition: all 0.3s ease;
    transform: translateY(0);
  }
  
  .hero-button:nth-child(1) { animation-delay: 0.1s; }
  .hero-button:nth-child(2) { animation-delay: 0.2s; }
  .hero-button:nth-child(3) { animation-delay: 0.3s; }
  
  .hero-content {
    animation: fadeInLeft 1s ease-out forwards;
    opacity: 0;
    transform: translateX(-50px);
    animation-delay: 0.4s;
  }
  
  .hero-name {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(30px);
    animation-delay: 0.6s;
  }
  
  .hero-subtitle {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(30px);
    animation-delay: 0.8s;
  }
  
  .hero-description {
    opacity: 0;
  }
  
  .hero-social {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(30px);
    animation-delay: 1.4s;
  }
  
  /* Profile Image Animations */
  .hero-image-section {
    animation: fadeInRight 1s ease-out forwards;
    opacity: 0;
    transform: translateX(50px);
    animation-delay: 0.5s;
  }
  
  .profile-image-wrapper {
    position: relative;
    animation: profileImageFadeIn 0.8s ease-out forwards;
    opacity: 0;
    transform: scale(0.95);
    animation-delay: 0.7s;
    transition: transform 0.3s ease;
  }
  
  .profile-image-wrapper:hover {
    transform: scale(1.02);
  }
  
  .rotating-contour.startup-animation {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      rgba(139, 92, 246, 0.8),
      rgba(168, 85, 247, 0.6),
      rgba(59, 130, 246, 0.4),
      rgba(6, 182, 212, 0.3),
      rgba(139, 92, 246, 0.8)
    );
    z-index: 5;
    opacity: 0;
    animation: 
      fadeInContour 1s ease-out forwards,
      rotateContour 8s linear infinite;
    animation-delay: 1.2s, 1.2s;
  }

  .rotating-contour-secondary.startup-animation {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: conic-gradient(
      from 180deg,
      rgba(139, 92, 246, 0.4),
      rgba(168, 85, 247, 0.3),
      rgba(59, 130, 246, 0.2),
      rgba(6, 182, 212, 0.1),
      rgba(139, 92, 246, 0.4)
    );
    z-index: 4;
    opacity: 0;
    filter: blur(2px);
    animation: 
      fadeInContour 1s ease-out forwards,
      rotateContour 12s linear infinite reverse;
    animation-delay: 1.4s, 1.4s;
  }

  @keyframes rotateContour {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Hover Glow Effect */
  .hover-glow-effect {
    position: absolute;
    inset: -12px;
    border-radius: 50%;
    background: radial-gradient(circle,
      rgba(139, 92, 246, 0.4) 0%,
      rgba(168, 85, 247, 0.3) 30%,
      transparent 70%
    );
    z-index: 3;
    opacity: 0;
    filter: blur(8px);
    transition: all 0.4s ease;
    box-shadow: 0 0 40px 20px rgba(139, 92, 246, 0.3);
  }

  .profile-image-wrapper:hover .hover-glow-effect {
    opacity: 1;
    inset: -20px;
    filter: blur(14px);
    box-shadow: 0 0 80px 40px rgba(139, 92, 246, 0.5);
  }

  .profile-image-wrapper:hover .rotating-contour.startup-animation {
    animation-duration: 4s;
    opacity: 1;
  }

  .profile-image-wrapper:hover .rotating-contour-secondary.startup-animation {
    animation-duration: 6s;
    opacity: 0.8;
  }
  
  .profile-image {
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    position: relative;
  }
  
  .profile-image.loaded {
    opacity: 1;
  }
  
  .loading-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.5s ease-in-out;
    z-index: 10;
    border-radius: 50%;
  }
  
  .loading-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }
  
  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(139, 92, 246, 0.3);
    border-top: 3px solid #8b5cf6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  
  /* Social Links */
  .social-link {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--arclab-gray-300);
    transition: all 0.3s ease;
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }

  .social-link:hover {
    color: white;
    background: rgba(139, 92, 246, 0.2);
    border-color: rgba(139, 92, 246, 0.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(139, 92, 246, 0.3);
  }
  
  /* Scroll Indicator */
  .scroll-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: var(--arclab-gray-400);
    text-decoration: none;
    transition: all 0.3s ease;
    animation: fadeInUp 1s ease-out forwards;
    opacity: 0;
    animation-delay: 1.6s;
  }
  
  .scroll-link:hover {
    color: var(--arclab-gray-300);
    transform: translateY(-4px);
  }
  
  .scroll-mouse {
    width: 24px;
    height: 40px;
    border: 2px solid currentColor;
    border-radius: 12px;
    position: relative;
    animation: bounce 2s infinite;
  }
  
  .scroll-wheel {
    width: 3px;
    height: 8px;
    background: currentColor;
    border-radius: 2px;
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollWheel 2s infinite;
  }
  
  .scroll-text {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  
  /* Typography Enhancements */
  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    color: white;
    margin-bottom: 0;
  }
  
  /* Keyframe Animations */
  @keyframes fadeInDown {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes fadeInLeft {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  @keyframes fadeInRight {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes profileImageFadeIn {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  @keyframes fadeInContour {
    to {
      opacity: 1;
    }
  }
  
  @keyframes rotateContour {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  
  @keyframes bounce {
    0%, 20%, 53%, 80%, 100% {
      transform: translateY(0);
    }
    40%, 43% {
      transform: translateY(-8px);
    }
    70% {
      transform: translateY(-4px);
    }
    90% {
      transform: translateY(-2px);
    }
  }
  
  @keyframes scrollWheel {
    0%, 20% {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateX(-50%) translateY(16px);
      opacity: 0;
    }
  }
  
  /* Responsive Design */
  @media (max-width: 1024px) {
    .hero-image-section {
      margin-top: 0;
    }
    
    .profile-image {
      width: 280px !important;
      height: 280px !important;
    }
  }
  
  @media (max-width: 768px) {
    .hero-header {
      margin-bottom: 2rem;
    }

    /* Give room for the scroll indicator at the bottom */
    #hero .arclab-container {
      padding-bottom: 5rem;
    }

    .profile-image {
      width: 240px !important;
      height: 240px !important;
    }
    
    .hero-content {
      text-align: center;
    }
    
    .hero-social {
      justify-content: center;
    }
  }
  
  @media (max-width: 480px) {
    .hero-header {
      margin-bottom: 1.5rem;
    }

    .hero-header .flex a {
      padding: 7px 11px;
      font-size: 0.75rem;
      gap: 6px;
    }

    .profile-image {
      width: 200px !important;
      height: 200px !important;
    }

    .social-link {
      width: 44px;
      height: 44px;
    }
  }
  
  /* Reduced motion accessibility */
  @media (prefers-reduced-motion: reduce) {
    .rotating-contour,
    .rotating-contour-secondary {
      animation: none;
    }
    
    .profile-ring {
      animation: none;
      opacity: 1;
    }
    
    .profile-image-wrapper:hover {
      transform: none;
    }
    
    .scroll-mouse,
    .scroll-wheel {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const profileImage = document.querySelector('.profile-image');
    const loadingOverlay = document.querySelector('.loading-overlay');
    
    if (profileImage && loadingOverlay) {
      // Check if image is already loaded
      if (profileImage.complete && profileImage.naturalHeight !== 0) {
        profileImage.classList.add('loaded');
        loadingOverlay.classList.add('hidden');
      } else {
        // Wait for image to load
        profileImage.addEventListener('load', function() {
          profileImage.classList.add('loaded');
          loadingOverlay.classList.add('hidden');
        });
        
        // Handle error case
        profileImage.addEventListener('error', function() {
          loadingOverlay.classList.add('hidden');
          console.warn('Profile image failed to load');
        });
      }
    }
    
    // Diffusion-style glitch reveal — operates on text nodes only so span colors stay visible
    const descEl = document.querySelector('.hero-description') as HTMLElement | null;
    if (descEl) {
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reducedMotion) {
        descEl.style.opacity = '1';
      } else {
        // Collect all text nodes inside the paragraph
        const walker = document.createTreeWalker(descEl, NodeFilter.SHOW_TEXT);
        const textNodes: Text[] = [];
        let n: Text | null;
        while ((n = walker.nextNode() as Text | null)) textNodes.push(n);

        // Snapshot original text per node
        const origTexts = textNodes.map(tn => tn.textContent || '');

        // Build flat char map: {nodeIdx, charIdx} for every non-whitespace char
        type CharEntry = { nodeIdx: number; charIdx: number };
        const charMap: CharEntry[] = [];
        const nodeCharLookup: Record<number, Record<number, number>> = {};
        origTexts.forEach((text, nodeIdx) => {
          nodeCharLookup[nodeIdx] = {};
          text.split('').forEach((char, charIdx) => {
            if (char.trim().length > 0) {
              nodeCharLookup[nodeIdx][charIdx] = charMap.length;
              charMap.push({ nodeIdx, charIdx });
            }
          });
        });

        // Shuffle for diffusion schedule
        const order = charMap.map((_, i) => i);
        for (let k = order.length - 1; k > 0; k--) {
          const j = Math.floor(Math.random() * (k + 1));
          [order[k], order[j]] = [order[j], order[k]];
        }

        const glyphs = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*<>[]{}|/\\';
        const locked = new Set<number>();
        let tick = 0;
        const lockPerTick = Math.max(1, Math.floor(order.length / 60));

        setTimeout(() => {
          descEl.style.opacity = '1';

          const interval = setInterval(() => {
            // Lock next batch of positions
            const start = tick * lockPerTick;
            for (let i = start; i < Math.min(start + lockPerTick, order.length); i++) {
              locked.add(order[i]);
            }
            tick++;

            // Update each text node independently — spans are untouched
            textNodes.forEach((tn, nodeIdx) => {
              const rebuilt = origTexts[nodeIdx].split('').map((char, charIdx) => {
                if (char.trim().length === 0) return char;
                const flatIdx = nodeCharLookup[nodeIdx][charIdx];
                return locked.has(flatIdx) ? char : glyphs[Math.floor(Math.random() * glyphs.length)];
              }).join('');
              tn.textContent = rebuilt;
            });

            if (locked.size >= order.length) {
              clearInterval(interval);
              // Restore exact originals
              textNodes.forEach((tn, i) => { tn.textContent = origTexts[i]; });
            }
          }, 40);
        }, 1200);
      }
    }

    // Enhanced scroll behavior for all anchor links
    const scrollLinks = document.querySelectorAll('a[href^="#"]');
    scrollLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        const target = document.querySelector(targetId);
        
        if (target) {
          const headerOffset = 80;
          const elementPosition = target.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
          
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }
      });
    });
  });
</script>