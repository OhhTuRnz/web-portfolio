---
---

<section id="hero" class="hero-section relative overflow-hidden">

  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900/95 via-slate-800/90 to-slate-900/95 z-10"></div>

  <div class="hero-inner arclab-container relative z-20">

    <div class="hero-grid">

      <!-- ── Left: bio ── -->
      <div class="hero-text">
        <div class="bio-row hero-anim" style="--d:0.3s">

          <!-- Portrait — sits in text column, doesn't touch the canvas -->
          <div class="portrait-wrap">
            <img
              src="/assets/images/carrusk_zen.webp"
              alt="Alejandro Carrasco"
              class="portrait-img"
              loading="eager"
              fetchpriority="high"
              width="140"
              height="200"
            />
          </div>

          <!-- Text -->
          <div class="bio-content">
            <h1 class="hero-name hero-anim" style="--d:0.45s">Alejandro Carrasco</h1>

            <p class="hero-bio hero-anim" style="--d:0.6s">
              I am an MS student on the PhD track in Aeronautics and Astronautics at
              <a href="https://aeroastro.mit.edu" class="bio-link" target="_blank" rel="noopener">MIT AeroAstro</a>,
              at the <a href="https://aeroastro.mit.edu/arclab/" class="bio-link" target="_blank" rel="noopener">ARC Lab</a>.
            </p>

            <p class="hero-bio hero-anim" style="--d:0.75s">
              My research focuses on large language models, autonomous agents,
              and multi-embodiment robotics training and its space use-cases.
            </p>

            <div class="hero-links hero-anim" style="--d:0.9s">
              <a href="#contact" class="bio-link">Email</a>
              <span class="sep">/</span>
              <a href="/assets/CarruskCV.pdf" target="_blank" rel="noopener" class="bio-link">CV</a>
              <span class="sep">/</span>
              <a href="https://scholar.google.com/citations?user=6KamS70AAAAJ&hl=en" target="_blank" rel="noopener" class="bio-link">Scholar</a>
              <span class="sep">/</span>
              <a href="https://github.com/OhhTuRnz" target="_blank" rel="noopener" class="bio-link">GitHub</a>
              <span class="sep">/</span>
              <a href="https://linkedin.com/in/carrusk" target="_blank" rel="noopener" class="bio-link">LinkedIn</a>
              <span class="sep">/</span>
              <a href="https://x.com/OhhTuRnz123" target="_blank" rel="noopener" class="bio-link">Twitter</a>
            </div>
          </div>

        </div>
      </div>

      <!-- ── Right: robot canvas only, no overlay ── -->
      <div class="hero-visual hero-anim" style="--d:0.4s">
        <canvas id="robot-canvas" class="robot-canvas"></canvas>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute inset-x-0 bottom-6 flex justify-center z-30">
    <a href="#publications" class="scroll-link">
      <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
      <span class="scroll-text">Scroll to explore</span>
    </a>
  </div>

</section>

<style>
  @font-face {
    font-family: 'Roinert';
    src: url('/fonts/RoinertOneRoundSqV2-9MpLy.ttf') format('truetype');
    font-display: swap;
  }

  /* ── Section ── */
  .hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .hero-inner {
    width: 100%;
    padding-top: 5rem;   /* clears the 64px fixed header */
    padding-bottom: 3rem;
  }
  @media (max-width: 479px) {
    .hero-inner { padding-top: 6rem; }
  }

  /* ── Two-column grid ── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid { grid-template-columns: 3fr 2fr; gap: 3.5rem; }
  }

  /* ── Bio row: portrait + text side by side ── */
  .bio-row {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }
  @media (max-width: 479px) {
    .bio-row {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .bio-content { align-items: center; }
    .hero-links  { justify-content: center; }
  }

  /* Portrait */
  .portrait-wrap { flex-shrink: 0; width: 130px; }
  @media (max-width: 479px) { .portrait-wrap { width: 100px; } }
  .portrait-img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    border: 1.5px solid rgba(139,92,246,0.4);
    box-shadow: 0 4px 24px rgba(0,0,0,0.5);
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Bio text column */
  .bio-content { display: flex; flex-direction: column; gap: 0.85rem; }

  .hero-name {
    font-family: 'Roinert', 'Inter', sans-serif;
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.05;
    margin: 0;
  }

  .hero-bio {
    font-size: 0.97rem;
    color: #94a3b8;
    line-height: 1.75;
    margin: 0;
  }

  .bio-link {
    color: #60a5fa;
    text-decoration: none;
    transition: color 0.2s;
  }
  .bio-link:hover { color: #93c5fd; text-decoration: underline; }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.92rem;
    padding-top: 0.2rem;
  }
  .sep { color: #334155; }

  /* ── Visual column ── */
  .hero-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 4/5;
    max-height: 520px;
  }
  .robot-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 1023px) {
    .hero-visual { aspect-ratio: 3/2; max-height: 300px; }
  }
  @media (max-width: 640px) {
    .hero-visual {
      width: 100%;
      height: clamp(160px, 30vh, 260px);
      aspect-ratio: unset;
      max-height: none;
    }
  }

  /* ── Animations ── */
  .hero-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: heroIn 0.7s ease both;
    animation-delay: var(--d, 0s);
  }
  @keyframes heroIn { to { opacity: 1; transform: translateY(0); } }

  /* Scroll indicator */
  .scroll-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: #475569;
    text-decoration: none;
    transition: all 0.3s ease;
    animation: heroIn 0.7s ease both;
    animation-delay: 1.1s;
  }
  .scroll-link:hover { color: #94a3b8; transform: translateY(-3px); }
  .scroll-mouse {
    width: 22px; height: 36px;
    border: 2px solid currentColor;
    border-radius: 11px;
    position: relative;
    animation: bounce 2.5s ease infinite;
  }
  .scroll-wheel {
    width: 3px; height: 7px;
    background: currentColor;
    border-radius: 2px;
    position: absolute;
    top: 6px; left: 50%;
    transform: translateX(-50%);
    animation: scrollWheel 2.5s ease infinite;
  }
  .scroll-text { font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; }
  @keyframes bounce {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }
  @keyframes scrollWheel {
    0%,20% { transform: translateX(-50%) translateY(0); opacity: 1; }
    100%    { transform: translateX(-50%) translateY(14px); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim { animation: none; opacity: 1; transform: none; }
    .scroll-mouse, .scroll-wheel { animation: none; }
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { MeshSurfaceSampler } from 'three/addons/math/MeshSurfaceSampler.js';

  const canvas = document.getElementById('robot-canvas') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('no canvas');

  const scene  = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(46, 1, 0.1, 100);
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
  renderer.setClearColor(0x000000, 0);

  // ── Resize ──
  function resize() {
    const w = canvas.clientWidth, h = canvas.clientHeight;
    if (!w || !h) return;
    renderer.setSize(w, h, false);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  }
  resize();
  const ro = new ResizeObserver(resize);
  ro.observe(canvas);

  // ── Mutable animation state (populated after GLTF loads) ──
  const robot = new THREE.Group();
  scene.add(robot);

  let pCount      = 0;
  let origArr     = new Float32Array(0);
  let phases      = new Float32Array(0);
  let posArr      = new Float32Array(0);
  let pointGeo: THREE.BufferGeometry | null = null;
  // Edge state
  let edgePairs:    number[]               = [];
  let edgePosArr:   Float32Array           = new Float32Array(0);
  let edgePosAttr:  THREE.BufferAttribute | null = null;

  let active   = true;
  let t        = 0;
  const DRIFT  = 0.012;
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function tick() {
    if (!active) return;
    requestAnimationFrame(tick);
    if (!reduced) {
      t += 0.010;
      robot.rotation.y = t * 0.30;

      if (pointGeo && pCount > 0) {
        for (let i = 0; i < pCount; i++) {
          const ph = phases[i] + t;
          posArr[i*3]   = origArr[i*3]   + Math.sin(ph * 1.30) * DRIFT;
          posArr[i*3+1] = origArr[i*3+1] + Math.sin(ph * 0.85 + 1.1) * DRIFT;
          posArr[i*3+2] = origArr[i*3+2] + Math.sin(ph * 1.10 + 2.3) * DRIFT;
        }
        pointGeo.attributes.position.needsUpdate = true;

        // Update edge endpoint positions from the drifted point positions
        if (edgePosAttr && edgePairs.length > 0) {
          const ep = edgePairs.length / 2;
          for (let e = 0; e < ep; e++) {
            const a = edgePairs[e*2], b = edgePairs[e*2+1];
            edgePosArr[e*6]   = posArr[a*3];   edgePosArr[e*6+1] = posArr[a*3+1]; edgePosArr[e*6+2] = posArr[a*3+2];
            edgePosArr[e*6+3] = posArr[b*3];   edgePosArr[e*6+4] = posArr[b*3+1]; edgePosArr[e*6+5] = posArr[b*3+2];
          }
          edgePosAttr.needsUpdate = true;
        }
      }
    }
    renderer.render(scene, camera);
  }

  // ── Load GLTF → sample surface points ──
  const loader = new GLTFLoader();
  loader.load('/assets/mesh_models/robo_face.glb', (gltf) => {
    const model = gltf.scene;

    // Compute bounding box BEFORE any transform
    const box    = new THREE.Box3().setFromObject(model);
    const center = box.getCenter(new THREE.Vector3());
    const size   = box.getSize(new THREE.Vector3());
    const maxDim = Math.max(size.x, size.y, size.z);
    const norm   = 3.2 / maxDim;

    // Center at origin, scale to fill canvas
    model.position.set(
      -center.x * norm,
      -center.y * norm,
      -center.z * norm
    );
    model.scale.setScalar(norm);
    model.updateMatrixWorld(true);

    // Camera distance: fit the full model height with padding
    const fovRad = camera.fov * (Math.PI / 180);
    const halfH  = (size.y * norm) / 2;
    const camZ   = halfH / Math.tan(fovRad / 2) * 1.25;
    camera.position.set(0, 0, camZ);
    camera.lookAt(0, 0, 0);

    // Collect meshes
    const meshes: THREE.Mesh[] = [];
    model.traverse(obj => { if ((obj as THREE.Mesh).isMesh) meshes.push(obj as THREE.Mesh); });
    if (meshes.length === 0) { tick(); return; }

    // Sample surface points
    const TOTAL   = 4000;
    const perMesh = Math.max(20, Math.ceil(TOTAL / meshes.length));
    const posData: number[] = [], colData: number[] = [];
    const _v = new THREE.Vector3(), _c = new THREE.Color();
    const cLow  = new THREE.Color(0x7c3aed); // purple (bottom)
    const cHigh = new THREE.Color(0x22d3ee); // cyan (top)

    // Re-evaluate bounding box after normalising
    const nb   = new THREE.Box3().setFromObject(model);
    const yMin = nb.min.y, yRange = nb.max.y - nb.min.y;

    meshes.forEach(mesh => {
      mesh.updateWorldMatrix(true, false);
      try {
        const sampler = new MeshSurfaceSampler(mesh).build();
        for (let i = 0; i < perMesh; i++) {
          sampler.sample(_v);
          _v.applyMatrix4(mesh.matrixWorld);
          posData.push(_v.x, _v.y, _v.z);
          const tt = Math.max(0, Math.min(1, (_v.y - yMin) / yRange));
          _c.lerpColors(cLow, cHigh, tt);
          colData.push(_c.r, _c.g, _c.b);
        }
      } catch (_) { /* skip degenerate mesh */ }
    });

    pCount  = posData.length / 3;
    origArr = new Float32Array(posData);
    phases  = new Float32Array(pCount);
    for (let i = 0; i < pCount; i++) phases[i] = Math.random() * Math.PI * 2;

    // ── Build edges via spatial grid (O(n) instead of O(n²)) ──
    const EDGE_THRESH  = 0.11;
    const MAX_NEIGH    = 3;   // max edges per point
    const cellSize     = EDGE_THRESH;
    const cellMap      = new Map<number, number[]>();
    const neighCount   = new Int32Array(pCount);

    function cellKey(cx: number, cy: number, cz: number) {
      return ((cx & 0x3ff) | ((cy & 0x3ff) << 10) | ((cz & 0x3ff) << 20));
    }

    for (let i = 0; i < pCount; i++) {
      const cx = Math.floor(origArr[i*3]   / cellSize);
      const cy = Math.floor(origArr[i*3+1] / cellSize);
      const cz = Math.floor(origArr[i*3+2] / cellSize);
      const k  = cellKey(cx, cy, cz);
      if (!cellMap.has(k)) cellMap.set(k, []);
      cellMap.get(k)!.push(i);
    }

    const pairs: number[] = [];
    const thresh2 = EDGE_THRESH * EDGE_THRESH;
    for (let i = 0; i < pCount; i++) {
      if (neighCount[i] >= MAX_NEIGH) continue;
      const cx = Math.floor(origArr[i*3]   / cellSize);
      const cy = Math.floor(origArr[i*3+1] / cellSize);
      const cz = Math.floor(origArr[i*3+2] / cellSize);
      for (let dx = -1; dx <= 1; dx++) for (let dy = -1; dy <= 1; dy++) for (let dz = -1; dz <= 1; dz++) {
        const neighbors = cellMap.get(cellKey(cx+dx, cy+dy, cz+dz));
        if (!neighbors) continue;
        for (const j of neighbors) {
          if (j <= i || neighCount[i] >= MAX_NEIGH || neighCount[j] >= MAX_NEIGH) continue;
          const ex = origArr[i*3]-origArr[j*3], ey = origArr[i*3+1]-origArr[j*3+1], ez = origArr[i*3+2]-origArr[j*3+2];
          if (ex*ex + ey*ey + ez*ez < thresh2) {
            pairs.push(i, j);
            neighCount[i]++; neighCount[j]++;
          }
        }
      }
    }

    edgePairs = pairs;
    const ep  = pairs.length / 2;
    edgePosArr = new Float32Array(ep * 6);
    const edgeColArr = new Float32Array(ep * 6);

    // Color each edge endpoint by Y gradient (same as points)
    for (let e = 0; e < ep; e++) {
      for (const [pt, off] of [[pairs[e*2], e*6], [pairs[e*2+1], e*6+3]] as [number,number][]) {
        const tt = Math.max(0, Math.min(1, (origArr[pt*3+1] - yMin) / yRange));
        _c.lerpColors(cLow, cHigh, tt);
        edgeColArr[off]   = _c.r;
        edgeColArr[off+1] = _c.g;
        edgeColArr[off+2] = _c.b;
        edgePosArr[off]   = origArr[pt*3];
        edgePosArr[off+1] = origArr[pt*3+1];
        edgePosArr[off+2] = origArr[pt*3+2];
      }
    }

    const edgeGeo = new THREE.BufferGeometry();
    edgePosAttr = new THREE.BufferAttribute(edgePosArr, 3);
    edgeGeo.setAttribute('position', edgePosAttr);
    edgeGeo.setAttribute('color', new THREE.BufferAttribute(edgeColArr, 3));
    robot.add(new THREE.LineSegments(edgeGeo, new THREE.LineBasicMaterial({
      vertexColors: true, transparent: true, opacity: 0.35,
    })));

    // Points on top of edges
    const geo = new THREE.BufferGeometry();
    const pa  = new THREE.BufferAttribute(new Float32Array(posData), 3);
    geo.setAttribute('position', pa);
    geo.setAttribute('color', new THREE.BufferAttribute(new Float32Array(colData), 3));
    pointGeo = geo;
    posArr   = pa.array as Float32Array;

    robot.add(new THREE.Points(geo, new THREE.PointsMaterial({
      size: 0.026, vertexColors: true, transparent: true, opacity: 0.92, sizeAttenuation: true,
    })));

    tick();
  },
  undefined,
  (err) => { console.error('GLTF load error', err); tick(); });

  document.addEventListener('fp-section-change', (e: any) => {
    active = e.detail?.id === 'hero';
    if (active) tick();
  });
  window.addEventListener('beforeunload', () => {
    active = false;
    ro.disconnect();
    renderer.dispose();
  });
</script>

