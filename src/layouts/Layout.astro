---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Alejandro Carrasco - AI Researcher & Robotics Engineer at MIT ARC Lab" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/carrusk.svg" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/assets/images/carrusk_zen.png" />
    <meta property="og:url" content="https://e1193dbe.carrusk-web-portfolio.pages.dev" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/assets/images/carrusk_zen.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Electrolize&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/arclab-theme.css">
  </head>
  <body class="bg-slate-900 text-white antialiased">
    <slot />

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const sections = [...document.querySelectorAll('main > section')];
        if (sections.length === 0) return;

        // ── Fallback: smooth-scroll for reduced-motion only ───────────────────
        if (reducedMotion) {
          document.querySelectorAll('a[href^="#"]').forEach(link => {
            link.addEventListener('click', function (e) {
              const href = (this as HTMLAnchorElement).getAttribute('href');
              if (!href || href.length <= 1) return;
              const target = document.querySelector(href);
              if (!target) return;
              e.preventDefault();
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
          });
          return;
        }

        // ── Fullpage mode ─────────────────────────────────────────────────────
        // Set initial state atomically with fp-init disabling transitions.
        // This prevents hero from flashing opacity 0→1 on load.
        document.body.classList.add('fp-mode', 'fp-init');
        sections[0].classList.add('fp-active');
        document.dispatchEvent(new CustomEvent('fp-section-change', { detail: { id: sections[0].id } }));

        // Enable transitions after first painted frame
        requestAnimationFrame(() => requestAnimationFrame(() => {
          document.body.classList.remove('fp-init');
        }));

        let current = 0;
        let locked = false;
        const LOCK_MS         = 650; // h-scroll snap cooldown
        const LOCK_SNAP       = 280; // cooldown after rAF-lerp commit (animation already done)
        const LOCK_DIRECT     = 480; // cooldown after CSS-transition commit (must outlast 0.45s)
        const LOCK_SLIDE_ENTRY = 820; // longer entry lock when landing on h-scroll sections

        // Boundary guard: keep true while h-scroll is actively moving; only allow
        // section navigation once the horizontal scroll has fully settled.
        let boundaryHit = false;
        let boundaryTimer: ReturnType<typeof setTimeout>;

        // Side-nav dots
        const nav = document.createElement('nav');
        nav.id = 'fp-nav';
        nav.setAttribute('aria-label', 'Page sections');
        sections.forEach((_, i) => {
          const dot = document.createElement('button');
          dot.className = 'fp-dot' + (i === 0 ? ' fp-dot-active' : '');
          dot.setAttribute('aria-label', `Section ${i + 1}`);
          dot.addEventListener('click', () => goTo(i));
          nav.appendChild(dot);
        });
        document.body.appendChild(nav);

        function updateDots() {
          nav.querySelectorAll('.fp-dot').forEach((d, i) =>
            d.classList.toggle('fp-dot-active', i === current)
          );
        }

        // ── Horizontal-scroll section helpers (.fp-scroll-x) ─────────────────
        function getHScroll(section: HTMLElement) {
          const vp = section.querySelector<HTMLElement>('.fp-scroll-x');
          if (!vp || vp.scrollWidth <= vp.clientWidth + 4) return null;
          const w = vp.clientWidth;
          const cur = Math.round(vp.scrollLeft / w);
          const total = Math.round(vp.scrollWidth / w);
          const maxScroll = vp.scrollWidth - vp.clientWidth;
          return { vp, cur, total, w, atStart: vp.scrollLeft <= 4, atEnd: vp.scrollLeft >= maxScroll - 4 };
        }

        function scrollHTo(vp: HTMLElement, idx: number) {
          locked = true;
          vp.scrollTo({ left: idx * vp.clientWidth, behavior: 'smooth' });
          setTimeout(() => { locked = false; }, LOCK_MS);
        }

        // ── Section transitions — rAF-lerped fade + drift ───────────────────
        // Visual state runs in a requestAnimationFrame loop (60fps, decoupled
        // from wheel event rate). Wheel events only update a target value.
        // The lerp gives smooth acceleration/deceleration. No full-page slide.
        const DRIFT       = 24;   // px drift on outgoing/incoming sections
        const LERP        = 0.16; // per-frame lerp (higher = snappier, lower = floatier)
        const DRAG_THRESH = 380;  // cumulative delta needed to complete a transition

        let xDir     = 0;    // +1 | -1 | 0
        let xSection = -1;   // target section index
        let xProg    = 0;    // animated progress [0..1]
        let xTarget  = 0;    // target for xProg (wheel events update this)
        let xAccum   = 0;    // accumulated wheel delta
        let xRaf     = 0;
        let xIdle: ReturnType<typeof setTimeout>;

        // Apply opacity + drift to both sections based on current progress
        function xApply(p: number) {
          if (xSection < 0) return;
          sections[current].style.opacity   = String(1 - p);
          sections[current].style.transform = `translateY(${xDir > 0 ? -p * DRIFT : p * DRIFT}px)`;
          sections[xSection].style.opacity  = String(p);
          sections[xSection].style.transform = `translateY(${xDir > 0 ? (1-p)*DRIFT : -(1-p)*DRIFT}px)`;
        }

        // Commit or cancel — called when lerp settles at xTarget
        function xFinish(commit: boolean) {
          xRaf = 0;
          clearTimeout(xIdle);
          const toIdx = xSection, fromIdx = current;
          // Set inline styles to match what CSS will give after cleanup,
          // then disable transition so cssText removal causes zero visual change.
          sections[fromIdx].style.transition = 'none';
          sections[toIdx].style.transition   = 'none';
          sections[fromIdx].style.opacity    = commit ? '0' : '1';
          sections[fromIdx].style.transform  = '';
          sections[toIdx].style.opacity      = commit ? '1' : '0';
          sections[toIdx].style.transform    = '';
          void sections[fromIdx].offsetHeight; // flush paint
          if (commit) {
            sections[fromIdx].classList.remove('fp-active');
            sections[toIdx].classList.add('fp-active');
          }
          sections[fromIdx].style.cssText = '';
          sections[toIdx].style.cssText   = '';
          if (commit) {
            sections[toIdx].dispatchEvent(new CustomEvent('fp-activate', { bubbles: false }));
            current = toIdx;
            updateDots();
            xDotFlipped = false;
            history.replaceState(null, '', '#' + (sections[toIdx].id || ''));
            document.dispatchEvent(new CustomEvent('fp-section-change', { detail: { id: sections[toIdx].id } }));
            locked = true;
            const snapDur = sections[toIdx].classList.contains('fp-slide-section') ? LOCK_SLIDE_ENTRY : LOCK_SNAP;
            setTimeout(() => { locked = false; xDir = 0; xSection = -1; xProg = 0; xTarget = 0; xAccum = 0; }, snapDur);
          } else {
            xDir = 0; xSection = -1; xProg = 0; xTarget = 0; xAccum = 0; xDotFlipped = false;
          }
        }

        // rAF loop — runs at display refresh rate regardless of input speed
        let xDotFlipped = false; // tracks whether nav dot was already updated mid-transition
        function xTick() {
          xProg += (xTarget - xProg) * LERP;
          const done = Math.abs(xTarget - xProg) < 0.002;
          if (done) xProg = xTarget;
          xApply(xProg);
          // Update nav dot at midpoint so it feels responsive, not laggy
          if (!xDotFlipped && xProg > 0.5 && xSection >= 0) {
            xDotFlipped = true;
            nav.querySelectorAll('.fp-dot').forEach((d, i) =>
              d.classList.toggle('fp-dot-active', i === xSection));
          } else if (xDotFlipped && xProg <= 0.5) {
            xDotFlipped = false;
            updateDots(); // rolled back past midpoint — restore current dot
          }
          if (done) { xFinish(xTarget > 0.5); return; }
          xRaf = requestAnimationFrame(xTick);
        }
        function xStart() { if (!xRaf) xRaf = requestAnimationFrame(xTick); }

        // Prepare both sections for a new drag transition (no animation yet)
        function xBegin(dir: number, tgtIdx: number) {
          xDir = dir; xSection = tgtIdx; xAccum = 0; xProg = 0; xTarget = 0; xDotFlipped = false;
          sections[tgtIdx].style.transition = 'none';
          sections[tgtIdx].style.opacity    = '0';
          sections[tgtIdx].style.transform  = `translateY(${dir > 0 ? DRIFT : -DRIFT}px)`;
          sections[current].style.transition = 'none';
          void sections[tgtIdx].offsetHeight;
        }

        // Direct navigation (keyboard / nav dots / links) — CSS transition, no drag
        function commitDirect(toIdx: number) {
          locked = true;
          const fromIdx    = current;
          const going_down = toIdx > fromIdx;
          const tr = 'opacity 0.45s ease, transform 0.45s ease';
          sections[toIdx].style.transition = 'none';
          sections[toIdx].style.opacity    = '0';
          sections[toIdx].style.transform  = `translateY(${going_down ? DRIFT : -DRIFT}px)`;
          void sections[toIdx].offsetHeight;
          requestAnimationFrame(() => {
            sections[fromIdx].style.transition = tr;
            sections[fromIdx].style.opacity    = '0';
            sections[fromIdx].style.transform  = `translateY(${going_down ? -DRIFT : DRIFT}px)`;
            sections[toIdx].style.transition   = tr;
            sections[toIdx].style.opacity      = '1';
            sections[toIdx].style.transform    = 'translateY(0)';
            sections[fromIdx].classList.remove('fp-active');
            sections[toIdx].classList.add('fp-active');
            sections[toIdx].dispatchEvent(new CustomEvent('fp-activate', { bubbles: false }));
            current = toIdx;
            updateDots();
            history.replaceState(null, '', '#' + (sections[toIdx].id || ''));
            document.dispatchEvent(new CustomEvent('fp-section-change', { detail: { id: sections[toIdx].id } }));
          });
          const directDur = sections[toIdx].classList.contains('fp-slide-section') ? LOCK_SLIDE_ENTRY : LOCK_DIRECT;
          setTimeout(() => {
            sections[fromIdx].style.cssText = '';
            sections[toIdx].style.cssText   = '';
            locked = false;
          }, directDur);
        }

        function goTo(idx: number, resetScroll = true) {
          if (locked || idx < 0 || idx >= sections.length || idx === current) return;
          if (xDir !== 0) {
            cancelAnimationFrame(xRaf); xRaf = 0; clearTimeout(xIdle);
            xFinish(false); // cancel any in-progress drag
          }
          if (resetScroll) {
            sections[idx].scrollTop = 0;
            const vp = sections[idx].querySelector<HTMLElement>('.fp-scroll-x');
            if (vp) {
              const targetLeft = idx > current ? 0 : vp.scrollWidth - vp.clientWidth;
              vp.scrollTo({ left: targetLeft, behavior: 'instant' });
            }
          }
          commitDirect(idx);
        }

        // Wheel — only updates xTarget; rAF loop handles the visuals
        window.addEventListener('wheel', (e) => {
          e.preventDefault();
          if (locked) return;
          const s  = sections[current];
          const d  = e.deltaY;
          const hs = getHScroll(s);

          if (hs) {
            if (xDir !== 0) { xTarget = 0; xStart(); return; }
            if (d > 0 && !hs.atEnd) {
              hs.vp.scrollLeft += Math.abs(d) * 2;
              clearTimeout(boundaryTimer);
              boundaryHit = true;
              boundaryTimer = setTimeout(() => { boundaryHit = false; }, 400);
              return;
            }
            if (d < 0 && !hs.atStart) {
              hs.vp.scrollLeft -= Math.abs(d) * 2;
              clearTimeout(boundaryTimer);
              boundaryHit = true;
              boundaryTimer = setTimeout(() => { boundaryHit = false; }, 400);
              return;
            }
            // At boundary — only navigate once horizontal scroll has settled
            if (boundaryHit) return;
            if (d > 0) goTo(current + 1);
            else if (d < 0) goTo(current - 1);
            return;
          }

          const atBottom = s.scrollTop + s.clientHeight >= s.scrollHeight - 2;
          const atTop    = s.scrollTop <= 2;
          if (d > 0 && !atBottom) { s.scrollTop += d; if (xDir !== 0) { xTarget = 0; xStart(); } return; }
          if (d < 0 && !atTop)    { s.scrollTop += d; if (xDir !== 0) { xTarget = 0; xStart(); } return; }

          const newDir = d > 0 ? 1 : -1;
          const tgtIdx = current + newDir;
          if (tgtIdx < 0 || tgtIdx >= sections.length) return;

          if (xDir !== 0 && newDir !== xDir) { xTarget = 0; xStart(); return; }
          if (xDir === 0) xBegin(newDir, tgtIdx);

          xAccum  += Math.abs(d);
          xTarget  = Math.min(xAccum / DRAG_THRESH, 1);

          // Snap when scrolling stops
          clearTimeout(xIdle);
          xIdle = setTimeout(() => {
            xTarget = xProg >= 0.3 ? 1 : 0;
            xStart();
          }, 140);

          xStart();
        }, { passive: false });

        // Keyboard
        window.addEventListener('keydown', (e) => {
          if (locked) return;
          const s = sections[current];
          const hs = getHScroll(s);
          if (e.key === 'ArrowDown' || e.key === 'PageDown') {
            e.preventDefault();
            if (hs) {
              if (!hs.atEnd) scrollHTo(hs.vp, hs.cur + 1); else goTo(current + 1);
            } else if (s.scrollTop + s.clientHeight >= s.scrollHeight - 2) {
              goTo(current + 1);
            } else { s.scrollTop += 120; }
          } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
            e.preventDefault();
            if (hs) {
              if (!hs.atStart) scrollHTo(hs.vp, hs.cur - 1); else goTo(current - 1);
            } else if (s.scrollTop <= 2) {
              goTo(current - 1);
            } else { s.scrollTop -= 120; }
          }
        });

        // Touch — native horizontal scroll handles swipe on fp-scroll-x elements;
        // vertical swipe still navigates sections
        let touchX = 0;
        let touchY = 0;
        window.addEventListener('touchstart', e => {
          touchX = e.touches[0].clientX;
          touchY = e.touches[0].clientY;
        }, { passive: true });
        window.addEventListener('touchend', e => {
          if (locked) return;
          const dx = touchX - e.changedTouches[0].clientX;
          const dy = touchY - e.changedTouches[0].clientY;
          const s = sections[current];
          const hs = getHScroll(s);

          if (hs && Math.abs(dx) > Math.abs(dy)) {
            // Horizontal swipe — native scroll handles it; just check boundary for section nav
            if (Math.abs(dx) < 48) return;
            if (dx > 0 && hs.atEnd)   { goTo(current + 1); return; }
            if (dx < 0 && hs.atStart) { goTo(current - 1); return; }
            return;
          }

          if (Math.abs(dy) < 48) return;
          if (hs) {
            // Vertical swipe on h-scroll section → navigate sections if at boundary
            if (dy > 0 && hs.atEnd)   goTo(current + 1);
            if (dy < 0 && hs.atStart) goTo(current - 1);
            return;
          }
          if (dy > 0 && s.scrollTop + s.clientHeight >= s.scrollHeight - 2) goTo(current + 1);
          else if (dy < 0 && s.scrollTop <= 2) goTo(current - 1);
        }, { passive: true });

        // Header nav links
        document.querySelectorAll('a[href^="#"]').forEach(link => {
          link.addEventListener('click', (e) => {
            const href = (link as HTMLAnchorElement).getAttribute('href');
            if (!href || href.length <= 1) return;
            const idx = sections.findIndex(s => '#' + s.id === href);
            if (idx >= 0) { e.preventDefault(); goTo(idx); }
          });
        });

        // Honour initial URL hash
        if (location.hash) {
          const idx = sections.findIndex(s => '#' + s.id === location.hash);
          if (idx > 0) setTimeout(() => goTo(idx, false), 150);
        }
      });
    </script>

    <style is:global>
      /* ── Fullpage layout ── */
      body.fp-mode { overflow: hidden; }

      body.fp-mode main {
        position: fixed;
        inset: 0;
        overflow: hidden;
      }

      body.fp-mode main > section {
        position: absolute;
        inset: 0;
        overflow-y: auto;
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.48s ease, transform 0.48s ease;
        will-change: opacity, transform;
        display: flex;
        flex-direction: column;
      }

      body.fp-mode main > section.fp-active {
        opacity: 1;
        pointer-events: auto;
      }

      /* Kill transitions during initial setup — prevents flash on load */
      body.fp-mode.fp-init main > section {
        transition: none !important;
      }

      /* Push content below the 64px fixed header; breathing room at bottom */
      body.fp-mode main > section:not(#hero) {
        padding-top: 72px !important;
        padding-bottom: 2rem !important;
      }

      /* Center content vertically when it fits; scrolls naturally when it overflows */
      body.fp-mode main > section:not(#hero) > * {
        flex-shrink: 0;
        margin-top: auto;
        margin-bottom: auto;
        width: 100%;
      }

      /* fp-slide-section (e.g. awards carousel): fill full height */
      body.fp-mode main > .fp-slide-section {
        padding-bottom: 0 !important;
      }
      body.fp-mode main > .fp-slide-section > * {
        margin-top: 0 !important;
        margin-bottom: 0 !important;
        flex: 1 !important;
        min-height: 0 !important;
      }

      /* Footer unreachable in fp-mode */
      body.fp-mode footer { display: none; }

      /* ── Side-nav dots ── */
      #fp-nav {
        position: fixed;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        z-index: 200;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .fp-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.12);
        cursor: pointer;
        padding: 0;
        transition: all 0.3s ease;
      }

      .fp-dot.fp-dot-active {
        background: rgba(255, 255, 255, 0.85);
        transform: scale(1.5);
        border-color: transparent;
      }

      @media (max-width: 768px) {
        #fp-nav { display: none; }
      }
    </style>
  </body>
</html>
