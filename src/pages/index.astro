---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Publications from '../components/Publications.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import AwardsList from '../components/AwardsList.astro';
import Affiliations from '../components/Affiliations.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import StarParticleBackground from '../components/StarParticleBackground.astro';
---

<Layout title="Alejandro Carrasco">
  <!-- Stars live outside <main> so fp-mode section opacity never hides them -->
  <StarParticleBackground />
  <Header />
  <main>
    <Hero />
    <Publications />
    <ProjectShowcase />
    <AwardsList />
    <Affiliations />
    <Contact />
  </main>
  <Footer />
</Layout>
